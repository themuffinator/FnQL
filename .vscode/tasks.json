{
  "version": "2.0.0",
  "options": {
    "cwd": "${workspaceFolder}"
  },
  "tasks": [
    {
      "label": "meson: setup",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\build-release.ps1",
        "-SetupOnly",
        "-Platform",
        "Win32",
        "-BuildDir",
        "meson\\build\\win32"
      ],
      "problemMatcher": []
    },
    {
      "label": "meson: build (Steam)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\build-release.ps1",
        "-Platform",
        "Win32",
        "-BuildDir",
        "meson\\build\\win32",
        "-Target",
        "both",
        "-Renderers",
        "glx,vk,rtx",
        "-Archive",
        "-WithSteam"
      ],
      "problemMatcher": [
        "$gcc",
        "$msCompile"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "meson: build Win32 debug (Steam)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\build-release.ps1",
        "-Configuration",
        "Debug",
        "-Platform",
        "Win32",
        "-BuildDir",
        "meson\\build\\win32-debug",
        "-Target",
        "both",
        "-Renderers",
        "glx,vk,rtx",
        "-Archive",
        "-WithSteam"
      ],
      "problemMatcher": [
        "$gcc",
        "$msCompile"
      ]
    },
    {
      "label": "meson: build RTX (Steam)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\build-release.ps1",
        "-Platform",
        "Win32",
        "-BuildDir",
        "meson\\build\\win32-rtx",
        "-Target",
        "client",
        "-Renderer",
        "rtx",
        "-WithSteam"
      ],
      "problemMatcher": [
        "$gcc",
        "$msCompile"
      ]
    },
    {
      "label": "meson: build x64 (Steam)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\build-release.ps1",
        "-Platform",
        "x64",
        "-BuildDir",
        "meson\\build",
        "-Target",
        "both",
        "-Renderers",
        "glx,vk,rtx",
        "-Archive",
        "-WithSteam"
      ],
      "problemMatcher": [
        "$gcc",
        "$msCompile"
      ]
    },
    {
      "label": "meson: test",
      "type": "shell",
      "command": "meson",
      "args": [
        "test",
        "-C",
        "meson/build/win32",
        "--print-errorlogs"
      ],
      "dependsOn": [
        "meson: build (Steam)"
      ],
      "problemMatcher": []
    },
    {
      "label": "Release: Build FnQL Full",
      "dependsOrder": "sequence",
      "dependsOn": [
        "meson: build (Steam)"
      ],
      "problemMatcher": []
    },
    {
      "label": "Release: Runtime Sweep x64 GLx",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}\\scripts\\glx_runtime_sweep.py",
        "--exe",
        "${workspaceFolder}\\meson\\build\\fnql.x64.exe",
        "--renderers",
        "glx,vk",
        "--switch-sequence",
        "glx,vk,glx,vk",
        "--maps",
        "q3dm1",
        "--profile",
        "glx-parity"
      ],
      "dependsOn": [
        "meson: build x64 (Steam)"
      ],
      "problemMatcher": []
    }
  ]
}
