{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "OpenGL (Steam / Retail QL / Win32)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}\\meson\\build\\win32\\fnql.exe",
      "args": ["+set", "r_fullscreen", "0", "+set", "cl_renderer", "opengl", "+set", "com_steamIntegration", "1", "+set", "cl_webuiEnable", "1"],
      "cwd": "${workspaceFolder}\\meson\\build\\win32",
      "preLaunchTask": "meson: build (Steam)",
      "stopAtEntry": false,
      "console": "internalConsole"
    },
