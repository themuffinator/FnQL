#version 450

layout(set = 0, binding = 0) uniform UBO {
	// light/env parameters:
	vec4 eyePos;				// vertex
	vec4 lightPos;				// vertex: light origin
	vec4 lightColor;			// fragment: rgb + 1/(r*r)
	vec4 lightVector;			// fragment: linear dynamic light
	// fog parameters:
	vec4 fogDistanceVector;		// vertex
	vec4 fogDepthVector;		// vertex
	vec4 fogEyeT;				// vertex
	vec4 fogColor;				// fragment
	vec4 texFactors;			// fragment
	vec4 depthFadeInfo;			// fragment
	vec4 depthFadeScale;		// fragment
	vec4 depthFadeBias;			// fragment
	vec4 dlightFactors;			// fragment
};

layout(set = 1, binding = 0) uniform sampler2D texture0;
#ifdef USE_FOG
layout(set = 2, binding = 0) uniform sampler2D fogtexture;
#endif
layout(set = 3, binding = 0) uniform sampler2D dlight_shadow_texture;

layout(location = 0) centroid in vec2 frag_tex_coord;
layout(location = 1) in vec3 N;  // normalized object-space normal vector
layout(location = 2) in vec4 L;  // object-space light vector
layout(location = 3) in vec4 V;  // object-space view vector
#ifdef USE_FOG
layout(location = 4) in vec2 fog_tex_coord;
#endif

layout(location = 0) out vec4 out_color;

layout (constant_id = 0) const int alpha_test_func = 0;
layout (constant_id = 1) const float alpha_test_value = 0.0;
//layout (constant_id = 2) const float depth_fragment = 0.85;
layout (constant_id = 3) const int alpha_to_coverage = 0;
//layout (constant_id = 4) const int color_mode = 0;
layout (constant_id = 5) const int abs_light = 0;
layout (constant_id = 11) const int dlight_shadow = 0;

float CorrectAlpha(float threshold, float alpha, vec2 tc)
{
	ivec2 ts = textureSize(texture0, 0);
	float dx = max(abs(dFdx(tc.x * float(ts.x))), 0.001);
	float dy = max(abs(dFdy(tc.y * float(ts.y))), 0.001);
	float dxy = max(dx, dy); // apply the smallest boost
	float scale = max(1.0 / dxy, 1.0);
	float ac = threshold + (alpha - threshold) * scale;
	return ac;
}

float DlightShadowFactor()
{
	if (dlight_shadow == 0 || dlightFactors.y <= 0.0 || depthFadeScale.w <= 0.0)
		return 1.0;

	if (depthFadeBias.y > 0.5) {
		vec3 lightToFrag = -L.xyz;
		vec3 spotDir = normalize(lightVector.xyz);
		float spotDist = dot(lightToFrag, spotDir);
		float zNear = depthFadeInfo.x;
		float zFar = depthFadeInfo.y;
		float tanHalfFov = max(depthFadeInfo.w, 0.0001);

		if (spotDist <= zNear || spotDist >= zFar)
			return 1.0;

		vec3 spotRight = vec3(spotDir.z, -spotDir.x, spotDir.y);
		spotRight = normalize(spotRight - spotDir * dot(spotRight, spotDir));
		vec3 spotUp = cross(spotRight, spotDir);
		vec2 projected = vec2(
			-dot(lightToFrag, spotRight),
			-dot(lightToFrag, spotUp)) / (spotDist * tanHalfFov);
		float coneRadius2 = dot(projected, projected);
		if (coneRadius2 > 1.0)
			return 1.0;
		vec2 localUV = vec2(0.5) + projected * 0.5;

		if (any(lessThan(localUV, vec2(0.0))) || any(greaterThan(localUV, vec2(1.0))))
			return 1.0;

		float tileSize = depthFadeScale.z;
		vec2 atlasSize = vec2(textureSize(dlight_shadow_texture, 0));
		float texelInset = 1.0 / tileSize;
		localUV = clamp(localUV, vec2(texelInset), vec2(1.0 - texelInset));
		vec2 atlasUV = (depthFadeScale.xy + localUV * tileSize) / atlasSize;

		float depthRange = max(zFar - zNear, 1.0);
		float receiverNDotL = clamp(abs(dot(normalize(N), normalize(L.xyz))), 0.0, 1.0);
		float receiverSlope = 1.0 - receiverNDotL;
		float receiverBias = depthFadeInfo.z * (0.125 + 0.375 * receiverSlope);
		float texelWorldBias = max(2.0 * spotDist * tanHalfFov / tileSize, 0.125);
		receiverBias = min(receiverBias, texelWorldBias);
		float biasedDist = max(spotDist - receiverBias, zNear);
		float forwardDepth = zFar / depthRange - (zFar * zNear) / (depthRange * biasedDist);
		float reversedDepth = (zFar * zNear) / (depthRange * biasedDist) - zNear / depthRange;
		float receiverDepth = mix(forwardDepth, reversedDepth, depthFadeBias.x);
		vec2 shadowTexel = 1.0 / atlasSize;
		float filterInner = dlightFactors.z;
		float filterOuter = dlightFactors.w;
		float sampleDepth0 = texture(dlight_shadow_texture, atlasUV + shadowTexel * vec2(-filterOuter, -filterInner)).r;
		float sampleDepth1 = texture(dlight_shadow_texture, atlasUV + shadowTexel * vec2( filterInner, -filterOuter)).r;
		float sampleDepth2 = texture(dlight_shadow_texture, atlasUV + shadowTexel * vec2(-filterInner,  filterOuter)).r;
		float sampleDepth3 = texture(dlight_shadow_texture, atlasUV + shadowTexel * vec2( filterOuter,  filterInner)).r;
		float forwardOcclusion =
			(1.0 - step(receiverDepth, sampleDepth0)) +
			(1.0 - step(receiverDepth, sampleDepth1)) +
			(1.0 - step(receiverDepth, sampleDepth2)) +
			(1.0 - step(receiverDepth, sampleDepth3));
		float reversedOcclusion =
			step(receiverDepth, sampleDepth0) +
			step(receiverDepth, sampleDepth1) +
			step(receiverDepth, sampleDepth2) +
			step(receiverDepth, sampleDepth3);
		float occlusion = 0.25 * mix(forwardOcclusion, reversedOcclusion, depthFadeBias.x);

		return clamp(1.0 - occlusion * dlightFactors.y, 0.0, 1.0);
	}

	vec3 shadowVec = -L.xyz;
	vec3 absVec = abs(shadowVec);
	float faceDist = max(max(absVec.x, absVec.y), absVec.z);
	if (faceDist <= 0.0001)
		return 1.0;

	int face;
	vec2 localUV;
	if (absVec.x >= absVec.y && absVec.x >= absVec.z) {
		face = shadowVec.x >= 0.0 ? 0 : 1;
		localUV = vec2(
			0.5 + 0.5 * (shadowVec.x >= 0.0 ? -shadowVec.y : shadowVec.y) / faceDist,
			0.5 - 0.5 * shadowVec.z / faceDist);
	} else if (absVec.y >= absVec.z) {
		face = shadowVec.y >= 0.0 ? 2 : 3;
		localUV = vec2(
			0.5 + 0.5 * (shadowVec.y >= 0.0 ? shadowVec.x : -shadowVec.x) / faceDist,
			0.5 - 0.5 * shadowVec.z / faceDist);
	} else {
		face = shadowVec.z >= 0.0 ? 4 : 5;
		localUV = vec2(
			0.5 - 0.5 * shadowVec.y / faceDist,
			0.5 + 0.5 * (shadowVec.z >= 0.0 ? shadowVec.x : -shadowVec.x) / faceDist);
	}

	float faceSize = depthFadeScale.x;
	float baseFace = depthFadeScale.y;
	float columns = depthFadeScale.z;
	vec2 atlasSize = vec2(textureSize(dlight_shadow_texture, 0));
	float texelInset = 1.0 / faceSize;
	localUV = clamp(localUV, vec2(texelInset), vec2(1.0 - texelInset));

	float tile = baseFace + float(face);
	float row = floor(tile / columns);
	float column = tile - row * columns;
	vec2 atlasUV = (vec2(column, row) * faceSize + localUV * faceSize) / atlasSize;

	float zNear = depthFadeInfo.x;
	float zFar = depthFadeInfo.y;
	float depthRange = max(zFar - zNear, 1.0);
	float receiverNDotL = clamp(abs(dot(normalize(N), normalize(L.xyz))), 0.0, 1.0);
	float receiverSlope = 1.0 - receiverNDotL;
	float receiverBias = depthFadeInfo.z * (0.125 + 0.375 * receiverSlope);
	float texelWorldBias = max(2.0 * faceDist / faceSize, 0.125);
	receiverBias = min(receiverBias, texelWorldBias);
	float biasedDist = max(faceDist - receiverBias, zNear);
	float forwardDepth = zFar / depthRange - (zFar * zNear) / (depthRange * biasedDist);
	float reversedDepth = (zFar * zNear) / (depthRange * biasedDist) - zNear / depthRange;
	float receiverDepth = mix(forwardDepth, reversedDepth, depthFadeBias.x);
	vec2 shadowTexel = 1.0 / atlasSize;
	float filterInner = dlightFactors.z;
	float filterOuter = dlightFactors.w;
	float sampleDepth0 = texture(dlight_shadow_texture, atlasUV + shadowTexel * vec2(-filterOuter, -filterInner)).r;
	float sampleDepth1 = texture(dlight_shadow_texture, atlasUV + shadowTexel * vec2( filterInner, -filterOuter)).r;
	float sampleDepth2 = texture(dlight_shadow_texture, atlasUV + shadowTexel * vec2(-filterInner,  filterOuter)).r;
	float sampleDepth3 = texture(dlight_shadow_texture, atlasUV + shadowTexel * vec2( filterOuter,  filterInner)).r;
	float forwardOcclusion =
		(1.0 - step(receiverDepth, sampleDepth0)) +
		(1.0 - step(receiverDepth, sampleDepth1)) +
		(1.0 - step(receiverDepth, sampleDepth2)) +
		(1.0 - step(receiverDepth, sampleDepth3));
	float reversedOcclusion =
		step(receiverDepth, sampleDepth0) +
		step(receiverDepth, sampleDepth1) +
		step(receiverDepth, sampleDepth2) +
		step(receiverDepth, sampleDepth3);
	float occlusion = 0.25 * mix(forwardOcclusion, reversedOcclusion, depthFadeBias.x);

	return clamp(1.0 - occlusion * dlightFactors.y, 0.0, 1.0);
}

void main() {
#ifdef USE_FOG
	vec4 fog = texture(fogtexture, fog_tex_coord);
#endif
	vec4 base = texture(texture0, frag_tex_coord);
	base.rgb *= texFactors.x;

	if ( alpha_to_coverage != 0 ) {
		if (alpha_test_func == 1) {
			base.a =  base.a > 0.0 ? 1.0 : 0.0;
		} else if (alpha_test_func == 2) {
			base.a = CorrectAlpha(alpha_test_value, 1.0 - base.a, frag_tex_coord);
		} else if (alpha_test_func == 3) {
			base.a = CorrectAlpha(alpha_test_value, base.a, frag_tex_coord);
		}
	} else
	// specialization: alpha-test function
	if (alpha_test_func == 1) {
		if (base.a == alpha_test_value) discard;
	} else if (alpha_test_func == 2) {
		if (base.a >= alpha_test_value) discard;
	} else if (alpha_test_func == 3) {
		if (base.a < alpha_test_value) discard;
	}

	vec4 lightColorRadius = lightColor;

#ifdef USE_LINE
	// project fragment on light vector
	float scale = clamp( dot( -L.xyz, lightVector.xyz ) * lightVector.w, 0.0, 1.0 );
	vec4 LL = lightVector * scale + L;

	vec3 nL = normalize(LL.xyz); // normalized light vector
	vec3 nV = normalize(V.xyz);	// normalized view vector

	// light intensity
	float intensFactor = 1.0 - (dot(LL.xyz, LL.xyz) * lightColorRadius.w);
#else
	vec3 nL = normalize(L.xyz);	// normalized light vector
	vec3 nV = normalize(V.xyz);	// normalized view vector

	// light intensity
	float intensFactor = 1.0 - dot(L.xyz, L.xyz) * lightColorRadius.w;
#endif

	if (intensFactor <= 0.0)
		discard;
	float smoothFactor = intensFactor * intensFactor * (3.0 - 2.0 * intensFactor);
	intensFactor = mix(intensFactor, smoothFactor, clamp(dlightFactors.x, 0.0, 1.0));
	vec3 intens = lightColorRadius.rgb * intensFactor;
	intens *= DlightShadowFactor();

#ifdef USE_FOG
	// modulate base by inverted fog alpha
	base.xyz = base.xyz * ( 1.0 - fog.a );
#endif

	vec3 nN = normalize(N);

	// Lambertian diffuse reflection term (N.L)
	float diffuse = dot(nN, nL);

	// specular reflection term (N.H)
	float specFactor = dot(nN, normalize(nL + nV));

	if ( abs_light != 0 )
	{
		// make sure that light and eye vectors are on the same plane side
		if ( diffuse * dot(nN, nV) <= 0 )
			discard;

		diffuse = abs( diffuse );
		specFactor = abs( specFactor );
	} else {
		diffuse = max( diffuse, 0.0 );
		specFactor = max( specFactor, 0.0 );
	}

	diffuse = min( diffuse, 1.0 );
	specFactor = min( specFactor, 1.0 );

	vec4 specBase = base * texFactors.z + vec4(texFactors.w);
	vec4 spec = vec4(pow(specFactor, max(texFactors.y, 1.0))) * specBase;

	out_color = (base * vec4(diffuse) + spec) * vec4(intens, 1.0);
}
